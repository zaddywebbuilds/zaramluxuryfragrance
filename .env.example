# ============================================================
# ZARAM LUXURY FRAGRANCE — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Supabase (Required for orders, products and admin)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Site URL (update when custom domain is connected)
VITE_SITE_URL=https://yourusername.github.io/zaram-luxury

# GitHub Pages base path (must match your repository name with slashes)
VITE_BASE_PATH=/zaram-luxury/

# WhatsApp number (digits only, with country code)
VITE_WHATSAPP_NUMBER=2348000000000

# ============================================================
# FUTURE PAYMENT (DO NOT ADD NOW — activate only when ready)
# ============================================================
# VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxx
# Note: Secret key must NEVER be in frontend env
#       Store it in Supabase Edge Function secrets only

# ============================================================
# ANALYTICS (Optional — leave empty to disable)
# ============================================================
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_META_PIXEL_ID=
# VITE_TIKTOK_PIXEL_ID=
